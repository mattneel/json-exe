{
  "name": "json-exe",
  "version": "0.0.1",
  "private": true,
  "description": "JSON.exe — a universal executable-object substrate: JSON extensions whose named fields are JavaScript slots run against a documented host context.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "examples": "pnpm --filter @json-exe/examples run all",
    "clean": "pnpm -r exec rm -rf dist",
    "check": "pnpm typecheck && pnpm test",
    "release": "pnpm -r build && pnpm -r publish"
  },
  "keywords": [
    "json",
    "plugins",
    "extensions",
    "scripting",
    "agents",
    "sandbox",
    "executable-json"
  ],
  "author": "",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
