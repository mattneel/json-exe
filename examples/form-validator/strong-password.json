{
  "$kind": "form-validator/v1",
  "id": "strong-password",
  "name": "Strong Password",
  "description": "Requires at least 12 characters including a number.",

  "validate": "return typeof ctx.value === 'string' && ctx.value.length >= 12 && /[0-9]/.test(ctx.value)",
  "message": "return 'Password must be at least 12 characters and include a number.'",
  "severity": "return 'error'",

  "$tests": [
    {
      "name": "rejects short passwords",
      "slot": "validate",
      "ctx": { "value": "abc1" },
      "expect": false
    },
    {
      "name": "rejects passwords without a number",
      "slot": "validate",
      "ctx": { "value": "abcdefghijkl" },
      "expect": false
    },
    {
      "name": "accepts a strong password",
      "slot": "validate",
      "ctx": { "value": "correcthorse1" },
      "expect": true
    }
  ]
}
