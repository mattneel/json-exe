{
  "name": "@json-exe/editor",
  "version": "0.0.1",
  "description": "Embeddable Monaco language features for JSON.exe: typed ctx completions, hover, signature help, diagnostics and return-type checking inside slot strings, plus a one-call extension editor component.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepack": "tsup",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.50.0"
  },
  "dependencies": {
    "@json-exe/runtime": "workspace:*",
    "@json-exe/testing": "workspace:*",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "monaco-editor": "^0.55.1"
  },
  "author": "Matt Neel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattneel/json-exe.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/mattneel/json-exe#readme",
  "bugs": "https://github.com/mattneel/json-exe/issues",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
