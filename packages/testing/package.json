{
  "name": "@json-exe/testing",
  "version": "0.1.0",
  "description": "Run the $tests embedded in a JSON.exe extension and report pass/fail.",
  "type": "module",
  "license": "MIT",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@json-exe/runtime": "workspace:*"
  }
}
