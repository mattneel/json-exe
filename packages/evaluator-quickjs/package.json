{
  "name": "@json-exe/evaluator-quickjs",
  "version": "0.1.0",
  "description": "Sandboxed JSON.exe evaluator backed by QuickJS-ng compiled to WebAssembly. Runs slot code with no host globals, memory limits, and CPU timeouts.",
  "type": "module",
  "license": "MIT",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@json-exe/runtime": "workspace:*",
    "quickjs-emscripten-core": "^0.32.0",
    "@jitl/quickjs-ng-wasmfile-release-sync": "^0.32.0"
  }
}
