{
  "name": "@json-exe/runtime",
  "version": "0.0.1",
  "description": "Core runtime for JSON.exe: define extension types, compile JSON extensions into JS slots, run them against ctx with return validation and tracing.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepack": "tsup",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "author": "Matt Neel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattneel/json-exe.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/mattneel/json-exe#readme",
  "bugs": "https://github.com/mattneel/json-exe/issues",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
