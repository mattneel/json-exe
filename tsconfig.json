{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@json-exe/runtime": ["./packages/runtime/src/index.ts"],
      "@json-exe/testing": ["./packages/testing/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "examples/**/*.ts"
  ],
  // @json-exe/editor needs the DOM lib (Monaco/HTMLElement); it is typechecked
  // via its own tsconfig, like the playground.
  "exclude": ["packages/editor"]
}
